# Copy this file to ".env" and fill in your values. Everything here is OPTIONAL —
# the app defaults to the ESPN data source, which needs no keys or proxy.

# Main data source:
#   espn   (default) ESPN's public site API — fresher scores, key-less + CORS,
#          no proxy. Undocumented/unofficial.
#   api    football-data.org (needs the token below + a CORS proxy in prod).
#   static bundled offline fixture schedule (no scores).
VITE_DATA_SOURCE=espn

# --- football-data.org (only when VITE_DATA_SOURCE=api) ---
# Free token: https://www.football-data.org/client/register. In dev it's sent via
# the Vite proxy; in production the token lives in the proxy (leave empty and set
# VITE_FOOTBALL_DATA_BASE to your proxy URL).
VITE_FOOTBALL_DATA_TOKEN=
# VITE_FOOTBALL_DATA_BASE=https://your-proxy.example.workers.dev

# --- Match-feed overlay: goal scorers + live commentary (optional) ---
# football-data.org's free tier has no scorers, so per-match scorers/commentary
# come from an overlay. Values:
#   espn        (default) ESPN's public API — COMPLETE scorers + live text
#               commentary, key-less and CORS (no proxy). Undocumented/unofficial.
#   thesportsdb documented/sanctioned, but goal timelines are often incomplete
#               (no commentary). Uses the public key "123".
#   none        disable the feature.
VITE_EVENTS_SOURCE=espn
# Only used when VITE_EVENTS_SOURCE=thesportsdb. "123" is the public test key.
# VITE_THESPORTSDB_KEY=123
