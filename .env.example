# Copy this file to ".env" and fill in your values.

# Which data source to use: "api" (live data from football-data.org) or
# "static" (bundled sample schedule, no key needed).
VITE_DATA_SOURCE=api

# football-data.org API token. Get a free one at https://www.football-data.org/client/register
# Required for local dev when VITE_DATA_SOURCE=api (sent as X-Auth-Token via the
# Vite dev proxy). In production the token lives in the proxy, not the client —
# leave this empty and set VITE_FOOTBALL_DATA_BASE to your proxy URL instead.
VITE_FOOTBALL_DATA_TOKEN=

# Base URL the app calls for football-data. Defaults to "/football-data" (the
# Vite dev proxy). In production, point this at your serverless proxy (e.g. a
# Cloudflare Worker) that injects the token and adds CORS headers.
# VITE_FOOTBALL_DATA_BASE=https://your-proxy.example.workers.dev

# --- Goal scorers overlay (optional) ---
# football-data.org's free tier has no scorers, so per-match goal scorers come
# from TheSportsDB (public, free, CORS-enabled — no proxy needed). Set to "none"
# to disable the feature. Community-sourced timelines can be incomplete; the UI
# flags partial data.
VITE_EVENTS_SOURCE=thesportsdb
# TheSportsDB API key. "123" is the shared public test key (default). For higher
# limits / fuller data, use your own Patreon key.
# VITE_THESPORTSDB_KEY=123
