# Copy this file to ".env" and fill in your values.

# Which data source to use: "static" (bundled sample data, no key needed)
# or "api" (live data from football-data.org).
VITE_DATA_SOURCE=static

# football-data.org API token. Get a free one at https://www.football-data.org/client/register
# Only required when VITE_DATA_SOURCE=api.
VITE_FOOTBALL_DATA_TOKEN=
